{
  "name": "pcm-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Project Code Management — AI 時代開發者第二大腦",
  "scripts": {
    "build": "pnpm -r build",
    "build:core": "pnpm --filter @pcm/core build",
    "build:cli": "pnpm --filter @pcm/cli build",
    "build:mcp": "pnpm --filter @pcm/mcp-server build",
    "build:storage": "pnpm --filter @pcm/storage build",
    "build:plugin-ts": "pnpm --filter @pcm/plugin-typescript build",
    "dev": "pnpm --filter @pcm/cli dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "clean": "pnpm -r clean"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3"]
  }
}
